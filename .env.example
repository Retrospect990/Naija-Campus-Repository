# Campus Pinduoduo: Safe-Buy Escrow System
# Environment Configuration Template
# Copy this to .env and fill in your values

# ============================================================================
# DATABASE CONFIGURATION (Supabase)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://user:password@host:5432/database_name

# ============================================================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================================================

# Paystack (Student Deposits)
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
PAYSTACK_ESCROW_ACCOUNT=your_paystack_escrow_account_id

# Flutterwave (Moderator Payouts)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE_your_public_key
FLUTTERWAVE_SECRET_KEY=FLWSCK_LIVE_your_secret_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret

# ============================================================================
# SMS GATEWAY CONFIGURATION (For PIN delivery)
# ============================================================================
# Twilio
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890  # Your Twilio phone number

# Alternative: Termii
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=SafeBuy  # 11 characters max

# ============================================================================
# PUSH NOTIFICATION CONFIGURATION
# ============================================================================
# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Flask
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your_super_secret_flask_key

# Commission Settings
COMMISSION_PERCENTAGE=10  # 10% commission on successful pools
COMMISSION_DESTINATION=PLATFORM  # Where commissions go

# Escrow Settings
CONFIRMATION_THRESHOLD=70  # 70% threshold for auto-release
POOL_EXPIRATION_DAYS=7  # How many days before auto-refund
ADMIN_PIN_LENGTH=6

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_LOGIN_ATTEMPTS=5  # Failed attempts before lockout
RATE_LIMIT_DEPOSIT_ATTEMPTS=10  # Attempts per hour
RATE_LIMIT_CONFIRMATION_ATTEMPTS=20  # Attempts per hour

# ============================================================================
# BACKEND SERVER CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=False

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.com
MOBILE_APP_URLS=https://yourdomain.com/mobile,com.campuspinduoduo.app

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/campus-pinduoduo/app.log
SENTRY_DSN=https://your_sentry_dsn

# Email Service (for support/billing)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SUPPORT_EMAIL=support@campuspinduoduo.com

# ============================================================================
# AWS/CLOUD STORAGE (For images, documents)
# ============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=campus-pinduoduo-images
S3_UPLOADS_DIR=uploads/

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# CORS Settings
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=True
CORS_MAX_AGE=3600

# Session Settings
SESSION_TIMEOUT_MINUTES=30
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Security Headers
ENABLE_CSRF_PROTECTION=True
HELMET_CSP_ENABLED=True

# ============================================================================
# TESTING CONFIGURATION
# ============================================================================
# Use TESTNET keys for development/staging
PAYSTACK_TESTNET_MODE=False  # Set True to use test API keys
FLUTTERWAVE_TESTNET_MODE=False

# Demo/Test Data
ENABLE_DEMO_DATA=False  # Seed with test users/pools
DEMO_ADMIN_PASSWORD=demo123

# ============================================================================
# DEPLOYMENT & DEVOPS
# ============================================================================
# Docker
DOCKER_IMAGE_NAME=campus-pinduoduo-api
DOCKER_IMAGE_TAG=latest

# Kubernetes (if applicable)
K8S_NAMESPACE=production
K8S_REPLICAS=3
K8S_MEMORY_LIMIT=512Mi

# Database Backup
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ============================================================================
# MOBILE APP CONFIGURATION
# ============================================================================
# API Version
API_VERSION=v1
MIN_APP_VERSION=1.0.0
CURRENT_APP_VERSION=1.0.1

# Features
FEATURE_BUDGET_RECOMMENDED=True
FEATURE_PAYMENT_HISTORY=True
FEATURE_DISPUTE_RESOLUTION=True
FEATURE_REFERRALS=False  # Coming soon

# ============================================================================
# ANALYTICS & METRICS
# ============================================================================
ANALYTICS_ENABLED=True
MIXPANEL_TOKEN=your_mixpanel_token
AMPLITUDE_API_KEY=your_amplitude_api_key

# Performance Metrics
ENABLE_APM=True  # Application Performance Monitoring
NEW_RELIC_LICENSE_KEY=your_new_relic_key

# ============================================================================
# DOCUMENTATION & NOTES
# ============================================================================
# 
# GETTING KEYS:
#
# 1. Supabase (Database):
#    - Go to supabase.com
#    - Create project
#    - Find API keys in Settings > API
#
# 2. Paystack (Student Deposits):
#    - Go to paystack.com
#    - Create account
#    - Find keys in Settings > API Keys & Webhooks
#    - Use test keys first (key starts with 'pk_test_')
#
# 3. Flutterwave (Moderator Payouts):
#    - Go to flutterwave.com
#    - Create account
#    - Find keys in Settings > API Keys
#    - Test keys available in Dashboard
#
# 4. Twilio (SMS for PINs):
#    - Go to twilio.com
#    - Create account
#    - Find credentials in Console > Account Info
#    - Purchase phone number in Console > Phone Numbers
#
# 5. Firebase (Push notifications):
#    - Go to firebase.google.com
#    - Create project
#    - Download service account JSON
#    - Extract credentials into environment vars
#
# DEPLOYMENT:
# 1. Development: Use test keys with DEBUG=True
# 2. Staging: Use live test accounts, DEBUG=False
# 3. Production: Use live keys, FLASK_ENV=production
#
# SECURITY REMINDERS:
# - NEVER commit .env file (add to .gitignore)
# - NEVER share SECRET_KEY or API keys
# - Rotate keys regularly
# - Enable 2FA on all service accounts
# - Use environment-specific configurations
